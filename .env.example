# ==============================================================================
# MayaDesk — environment configuration example
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# `.env` is git-ignored; only this `.env.example` template is tracked.
# ==============================================================================

# ------------------------------------------------------------------------------
# LiveKit (real-time voice transport — used by apps/agent and apps/web)
# ------------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ------------------------------------------------------------------------------
# Groq (LLM + STT inference — used by apps/agent)
# ------------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3

# ------------------------------------------------------------------------------
# App (shared config — used by packages/domain and apps/api)
# ------------------------------------------------------------------------------
# SQLite is the local dev default. To move to Postgres for production, swap
# this for a postgres+asyncpg URL — it's a one-line change; SQLAlchemy async
# handles the rest.
DATABASE_URL=sqlite+aiosqlite:///./maya.db
ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# Voice pipeline tuning (optional — used by apps/agent; sensible defaults apply)
# All are prefixed MAYA_VOICE_. Uncomment to override.
# ------------------------------------------------------------------------------
# MAYA_VOICE_PREEMPTIVE_GENERATION=true      # start replying before turn ends (latency)
# MAYA_VOICE_MIN_ENDPOINTING_DELAY=0.4       # pause (s) that ends the caller's turn
# MAYA_VOICE_MAX_ENDPOINTING_DELAY=6.0
# MAYA_VOICE_ALLOW_INTERRUPTIONS=true        # let the caller barge in over Maya
# MAYA_VOICE_MIN_INTERRUPTION_DURATION=0.5
# MAYA_VOICE_TURN_DETECTION=vad              # stt | vad | realtime_llm | manual
# MAYA_VOICE_VAD_MIN_SILENCE_DURATION=0.4
# MAYA_VOICE_VAD_ACTIVATION_THRESHOLD=0.5
# MAYA_VOICE_STT_MAX_RETRY=2
# MAYA_VOICE_LLM_MAX_RETRY=2
# MAYA_VOICE_TTS_MAX_RETRY=2
# MAYA_VOICE_PROVIDER_TIMEOUT=10.0
# MAYA_VOICE_MAX_UNRECOVERABLE_ERRORS=5
# MAYA_VOICE_TOOL_TIMEOUT_SECONDS=8.0        # cancel a DB action that hangs
# MAYA_VOICE_API_BASE_URL=http://localhost:8000  # where the agent pushes dashboard events

# ------------------------------------------------------------------------------
# Realtime + hardening (apps/api)
# ------------------------------------------------------------------------------
# Shared secret guarding POST /internal/events (agent -> API dashboard push).
# Leave unset in dev; set the SAME value for the API and the agent in prod.
# INTERNAL_EVENT_TOKEN=change-me
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT=120/minute
# RATE_LIMIT_TOKEN=10/minute

# ------------------------------------------------------------------------------
# Web (public — exposed to the browser bundle by Next.js, apps/web)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_API_URL=http://localhost:8000
